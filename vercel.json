{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "PYTHONPATH": "."
  },
  "crons": [
    {
      "path": "/api/webhooks/health-check",
      "schedule": "*/5 * * * *"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "memory": 512
    }
  }
}
